# ─────────────────────────────────────────────────────────────
# Infera — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ---- OpenRouter (LLM access) ----
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers (shown on OpenRouter dashboard)
OPENROUTER_APP_TITLE=Infera
OPENROUTER_APP_URL=http://localhost:3000

# ---- PostgreSQL (transactional store: conversations, messages) ----
POSTGRES_USER=infera
POSTGRES_PASSWORD=infera
POSTGRES_DB=infera
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- ClickHouse (analytics store: inference logs) ----
CLICKHOUSE_USER=infera
CLICKHOUSE_PASSWORD=infera
CLICKHOUSE_DB=infera
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# ---- Redpanda / Kafka (event broker) ----
# Inside the compose network use `redpanda:9092`; from the host use `localhost:19092`.
KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC_RAW=inference.logs.raw
KAFKA_TOPIC_DLQ=inference.logs.dlq

# ---- Grafana (dashboards) ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
